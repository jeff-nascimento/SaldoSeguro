{
  "name": "typescript-estudos-hibrido",
  "version": "1.0.0",
  "description": "Ambiente híbrido para estudos de TypeScript (Front e Back)",
  "type": "module",
  "scripts": {
    "dev": "webpack serve --config webpack.config.cjs",
    "build": "webpack --mode production --config webpack.config.cjs",
    "test:node": "tsx src/index.ts",
    "watch:node": "tsx watch src/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:silent": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watchAll --silent --noStackTrace"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/jest": "^29.5.14",
    "css-loader": "^7.1.4",
    "eslint": "^9.19.0",
    "eslint-plugin-prettier": "^5.2.3",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^15.14.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.4.2",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "validator": "^13.15.0"
  }
}
